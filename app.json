{
  "expo": {
    "name": "Oryalis",
    "slug": "oryalis",
    "scheme": "oryalis",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jptim09.oryalis",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Oryalis utilise l'appareil photo pour mettre à jour votre photo de profil.",
        "NSPhotoLibraryUsageDescription": "Oryalis accède à vos photos pour mettre à jour votre photo de profil.",
        "NSPhotoLibraryAddUsageDescription": "Oryalis peut enregistrer des photos dans votre bibliothèque.",
        "LSApplicationQueriesSchemes": ["whatsapp"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A2B4A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6D3BFF",
          "defaultChannel": "oryalis-relances"
        }
      ],
      "expo-localization",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Oryalis accède à vos photos pour mettre à jour votre photo de profil.",
          "cameraPermission": "Oryalis utilise l'appareil photo pour mettre à jour votre photo de profil."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Oryalis a besoin d'accéder à votre calendrier pour synchroniser vos rendez-vous."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a46318d3-1be7-4b61-93de-d90af0b256c2"
      }
    }
  }
}
